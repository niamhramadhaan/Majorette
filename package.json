{
  "name": "jemima",
  "version": "2.2.0",
  "description": "Open-source digital signage and media scheduling platform",
  "license": "BUSL-1.1",
  "author": "Niamh Ramadhaan",
  "repository": {
    "type": "git",
    "url": "https://github.com/niamhramadhaan/jemima.git"
  },
  "homepage": "https://github.com/niamhramadhaan/jemima#readme",
  "keywords": ["digital-signage", "media-player", "scheduling", "electron", "react"],
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"vite --port=3000 --host=0.0.0.0\"",
    "server": "node server.cjs",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "rough-notation": "^0.5.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "date-fns": "^4.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pigeon-maps": "^0.22.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "build": {
    "appId": "com.jemima.player",
    "productName": "JEMIMA Player",
    "files": [
      "dist/assets/**/*",
      "dist/index.html",
      "dist/favicon.png",
      "dist/logo.png",
      "server.cjs",
      "electron/**/*"
    ],
    "asarUnpack": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "public/logo.png",
        "to": "logo.png"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "JEMIMA Player"
    }
  }
}
